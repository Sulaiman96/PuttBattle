# ===========================================================================
# PuttBattle — Unreal Engine .gitignore (CONVENTIONS §9)
# Never commit generated/derived directories. Source, Config, Content and
# vendored plugin *source* are tracked; binaries/intermediates are not.
# ===========================================================================

# --- Engine-generated, per-machine, never committed ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Backup/

# Vendored plugins: keep their source, drop their build artifacts
Plugins/**/Binaries/
Plugins/**/Intermediate/
Plugins/**/DerivedDataCache/
Plugins/**/Saved/

# Node bridge dependencies (re-created by `npm install`)
Plugins/**/node_modules/
node_modules/

# --- IDE / tooling ---
.vs/
.vscode/
.idea/
*.sln
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.vsconfig
.vsconfig
UpgradeLog.htm

# --- Build artifacts that can leak outside Binaries/ ---
*.obj
*.pch
*.pdb
*.exe
*.dll
*.lib
*.a
*.so
*.dylib

# --- Map BuiltData is regenerated by the editor ---
*_BuiltData.uasset

# --- OS cruft ---
.DS_Store
Thumbs.db
