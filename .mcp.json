{
  "mcpServers": {
    "unreal": {
      "type": "stdio",
      "command": "node",
      "args": ["Plugins/UnrealClaude/Resources/mcp-bridge/index.js"],
      "env": {
        "UNREAL_MCP_URL": "http://localhost:3000"
      }
    },
    "vibeue": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y", "mcp-remote",
        "http://127.0.0.1:8088/mcp",
        "--transport", "http-only",
        "--allow-http",
        "--header", "Authorization:Bearer ${VIBEUE_API_KEY}"
      ],
      "env": {
        "NODE_OPTIONS": "--use-system-ca"
      }
    }
  }
}
