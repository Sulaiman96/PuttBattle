# ===========================================================================
# PuttBattle — Git LFS rules (CONVENTIONS §9)
# Large/binary UE asset types are stored via Git LFS so the repo stays light
# and merges don't corrupt binaries. `git lfs install` must have been run once.
# ===========================================================================
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap   filter=lfs diff=lfs merge=lfs -text
*.png    filter=lfs diff=lfs merge=lfs -text
*.fbx    filter=lfs diff=lfs merge=lfs -text
*.wav    filter=lfs diff=lfs merge=lfs -text

# Treat UE text config/source as normal text with LF-normalized diffs.
*.ini   text
*.cpp   text
*.h     text
*.cs    text
